# Mot de passe administrateur — INDISPENSABLE si le serveur est public (Railway).
# Protège toute l'app SAUF l'espace salarié (/moi). Identifiant : admin · mot de passe : ci-dessous.
PILOTRH_ADMIN_PASSWORD=change-moi

# Optionnel — active l'OCR des documents et l'assistant IA
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Optionnel — lecture automatique du .mdb si le serveur est DANS le réseau de l'usine.
# (Sur Railway/cloud, utilisez plutôt push_pointeuse.py côté usine.)
# PILOTRH_MDB_PATH=/mnt/pointeuse/attBackup.mdb
# PILOTRH_SYNC_MINUTES=60
